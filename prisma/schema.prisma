model StoreNoticeUser {
  storeNoticeId Int         @map("store_notice_id")
  storeNotice   StoreNotice @relation(fields: [storeNoticeId], references: [id], onDelete: Cascade)
  userId        Int         @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storeNoticeId, userId])
  @@map("store_notice_user")
}

model StoreNoticeShop {
  storeNoticeId Int         @map("store_notice_id")
  storeNotice   StoreNotice @relation(fields: [storeNoticeId], references: [id], onDelete: Cascade)
  shopId        Int         @map("shop_id")
  shop          Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([storeNoticeId, shopId])
  @@map("store_notice_shop")
}

model StoreNoticeRead {
  storeNoticeId Int         @map("store_notice_id")
  storeNotice   StoreNotice @relation(fields: [storeNoticeId], references: [id], onDelete: Cascade)
  userId        Int         @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRead        Boolean     @default(false) @map("is_read")

  @@id([storeNoticeId, userId])
  @@map("store_notice_read")
}

// ============================================================================
// MESSAGING
// ============================================================================

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId    Int      @map("shop_id")
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages     Message[]
  participants Participant[]

  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  participants Participant[]

  @@map("messages")
}

model Participant {
  id             Int             @id @default(autoincrement())
  conversationId Int             @map("conversation_id")
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  type           ParticipantType
  userId         Int             @map("user_id")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId         Int             @map("shop_id")
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  messageId      Int             @map("message_id")
  message        Message         @relation(fields: [messageId], references: [id], onDelete: Cascade)
  notify         Boolean         @default(false)
  lastRead       DateTime?       @map("last_read")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("participants")
}

model NotifyLog {
  id                  Int       @id @default(autoincrement())
  receiverId          Int       @map("receiver")
  receiver            User      @relation("NotifyReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  senderId            Int?      @map("sender")
  sender              User?     @relation("NotifySender", fields: [senderId], references: [id], onDelete: Cascade)
  notifyType          String?   @map("notify_type") @db.Text
  notifyReceiverType  String?   @map("notify_receiver_type") @db.Text
  isRead              Boolean   @default(false) @map("is_read")
  notifyTracker       String?   @map("notify_tracker") @db.Text
  notifyText          String?   @map("notify_text") @db.Text
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("notify_logs")
}

// ============================================================================
// FLASH SALE
// ============================================================================

model FlashSale {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(255)
  slug         String        @db.VarChar(255)
  description  String?       @db.Text
  startDate    DateTime      @default(now()) @map("start_date")
  endDate      DateTime      @map("end_date")
  saleStatus   Boolean       @default(false) @map("sale_status")
  type         FlashSaleType @default(percentage)
  rate         Int?
  saleBuilder  Json?         @map("sale_builder")
  image        Json?
  coverImage   Json?         @map("cover_image")
  language     String?       @db.VarChar(255)
  deletedAt    DateTime?     @map("deleted_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  requests FlashSaleRequest[]
  products FlashSaleProduct[]

  @@map("flash_sales")
}

model FlashSaleRequest {
  id                  Int       @id @default(autoincrement())
  title               String    @db.VarChar(255)
  flashSaleId         Int       @map("flash_sale_id")
  flashSale           FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  requestedProductIds Json?     @map("requested_product_ids")
  requestStatus       Boolean   @default(false) @map("request_status")
  note                String?   @db.VarChar(255)
  language            String    @default("en") @db.VarChar(255)
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  products FlashSaleRequestsProduct[]

  @@map("flash_sale_requests")
}

model FlashSaleProduct {
  flashSaleId Int       @map("flash_sale_id")
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([flashSaleId, productId])
  @@map("flash_sale_products")
}

model FlashSaleRequestsProduct {
  flashSaleRequestsId Int              @map("flash_sale_requests_id")
  flashSaleRequest    FlashSaleRequest @relation(fields: [flashSaleRequestsId], references: [id], onDelete: Cascade)
  productId           Int              @map("product_id")
  product              Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([flashSaleRequestsId, productId])
  @@map("flash_sale_requests_products")
}

// ============================================================================
// MISC: USER PROFILE / SETTING / MEDIA
// ============================================================================

model UserProfile {
  id            Int      @id @default(autoincrement())
  avatar        Json?
  bio           String?  @db.Text
  socials       Json?
  contact       String?  @db.VarChar(255)
  notifications Json?
  customerId    Int      @unique @map("customer_id")
  customer      User     @relation(fields: [customerId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model Setting {
  id        Int      @id @default(autoincrement())
  options   Json
  language  String   @default("en") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// Spatie Media Library — polymorphic (model_type / model_id), join manual
model Media {
  id                    BigInt    @id @default(autoincrement())
  modelType             String    @map("model_type") @db.VarChar(255)
  modelId               BigInt    @map("model_id")
  uuid                  String?   @db.VarChar(255)
  collectionName        String    @map("collection_name") @db.VarChar(255)
  name                  String    @db.VarChar(255)
  fileName              String    @map("file_name") @db.VarChar(255)
  mimeType              String?   @map("mime_type") @db.VarChar(255)
  disk                  String    @db.VarChar(255)
  conversionsDisk       String?   @map("conversions_disk") @db.VarChar(255)
  size                  BigInt
  manipulations         Json
  generatedConversions  Json      @map("generated_conversions")
  customProperties      Json      @map("custom_properties")
  responsiveImages      Json      @map("responsive_images")
  orderColumn           Int?      @map("order_column")
  createdAt             DateTime? @map("created_at")
  updatedAt             DateTime? @map("updated_at")

  @@index([modelType, modelId])
  @@map("media")
}
