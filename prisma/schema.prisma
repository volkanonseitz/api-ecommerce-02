  parent                 Order?        @relation("OrderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children               Order[]       @relation("OrderChildren")
  shopId                 Int?          @map("shop_id")
  shop                   Shop?         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  discount               Float?
  paymentGateway         String?       @map("payment_gateway") @db.VarChar(255)
  alteredPaymentGateway  String?       @map("altered_payment_gateway") @db.VarChar(255)
  shippingAddress        Json?         @map("shipping_address")
  billingAddress         Json?         @map("billing_address")
  logisticsProvider      Int?          @map("logistics_provider")
  deliveryFee            Float?        @map("delivery_fee")
  deliveryTime           String?       @map("delivery_time") @db.VarChar(255)
  orderStatus            OrderStatus   @default(PENDING) @map("order_status")
  paymentStatus          PaymentStatus @default(PENDING) @map("payment_status")
  deletedAt              DateTime?     @map("deleted_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  products         OrderProduct[]
  paymentIntents   PaymentIntent[]
  walletPoints     OrderWalletPoint[]
  refunds          Refund[]
  reviews          Review[]
  availabilities   Availability[]
  orderedFiles     OrderedFile[]

  @@map("orders")
}

