generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================================================
// ENUMS (berdasarkan file App\Enums)
// ============================================================

enum CouponType {
  fixed
  percentage
  free_shipping
}

enum DefaultStatusType {
  processing
  approved
  pending
  rejected
}

enum FlashSaleType {
  percentage
  fixed_rate
}

enum OrderStatus {
  order_pending // nilai: "order-pending"
  order_processing // "order-processing"
  order_completed // "order-completed"
  order_cancelled // "order-cancelled"
  order_refunded // "order-refunded"
  order_failed // "order-failed"
  order_at_local_facility // "order-at-local-facility"
  order_out_for_delivery // "order-out-for-delivery"
}

enum PaymentStatus {
  payment_pending // "payment-pending"
  payment_processing // "payment-processing"
  payment_success // "payment-success"
  payment_failed // "payment-failed"
  payment_reversal // "payment-reversal"
  payment_refunded // "payment-refunded"
  payment_cash_on_delivery // "payment-cash-on-delivery"
  payment_cash // "payment-cash"
  payment_wallet // "payment-wallet"
  payment_awaiting_approval // "payment-awaiting-for-approval"
}

enum ProductStatus {
  under_review
  approved
  rejected
  publish
  unpublish
  draft
}

enum ProductType {
  simple
  variable
}

enum ProductVisibilityStatus {
  visibility_private
  visibility_public
  visibility_protected
}

enum RefundPolicyStatus {
  approved
  pending
}

enum RefundPolicyTarget {
  vendor
  customer
}

enum RefundStatus {
  approved
  pending
  rejected
  processing
}

enum ResourceType {
  DROPOFF_LOCATION
  PICKUP_LOCATION
  PERSON
  DEPOSIT
  FEATURES
}

enum ShippingType {
  fixed
  percentage
  free_shipping
}

enum StoreNoticePriority {
  high
  medium
  low
}

enum StoreNoticeType {
  all_vendor
  specific_vendor
  all_shop
  specific_shop
}

enum WithdrawStatus {
  approved
  pending
  on_hold
  rejected
  processing
}

enum ParticipantType {
  shop
  user
}

// ============================================================================
// AUTH / USERS
// ============================================================================

model User {
  id                    Int       @id @default(autoincrement())
  name                  String
  email                 String    @unique
  emailVerifiedAt       DateTime? @map("email_verified_at")
  password              String?
  rememberToken         String?   @map("remember_token")
  isActive              Boolean   @default(true) @map("is_active")
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime? @map("locked_until")
  lastLoginAt           DateTime? @map("last_login_at")
  lastLoginIp           String?   @map("last_login_ip") @db.VarChar(45)
  lastLoginUserAgent    String?   @map("last_login_user_agent") @db.Text
  shopId                Int?      @map("shop_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // relasi "staff/vendor user ini terdaftar di toko mana" (users.shop_id)
  shop                  Shop?     @relation("UserCurrentShop", fields: [shopId], references: [id])

  // toko yang dimiliki user ini (shops.owner_id)
  ownedShops            Shop[]    @relation("ShopOwner")

  addresses             Address[]
  profile               UserProfile?
  wallet                Wallet?
  providers             Provider[]
  paymentGateways       PaymentGateway[]
  coupons               Coupon[]
  ordersAsCustomer      Order[]           @relation("OrderCustomer")
  reviews               Review[]
  questions             Question[]
  refunds               Refund[]
  feedbacks             Feedback[]
  abusiveReports        AbusiveReport[]
  wishlists             Wishlist[]
  faqs                  Faq[]
  termsAndConditions    TermsAndCondition[]
  conversations         Conversation[]
  messages              Message[]
  participants          Participant[]
  notifyLogsReceived    NotifyLog[]       @relation("NotifyReceiver")
  notifyLogsSent        NotifyLog[]       @relation("NotifySender")
  storeNoticesCreated   StoreNotice[]     @relation("StoreNoticeCreatedBy")
  storeNoticesUpdated   StoreNotice[]     @relation("StoreNoticeUpdatedBy")
  storeNoticeUser       StoreNoticeUser[]
  storeNoticeRead       StoreNoticeRead[]
  downloadTokens        DownloadToken[]
  orderedFiles          OrderedFile[]
  passwordHistory       PasswordHistory[]
  userSessions          UserSession[]
  userShops             UserShop[]
  ownershipTransfersFrom OwnershipTransfer[] @relation("TransferFrom")
  ownershipTransfersTo   OwnershipTransfer[] @relation("TransferTo")
  ownershipTransfersCreated OwnershipTransfer[] @relation("TransferCreatedBy")

  @@map("users")
}

// Laravel Sanctum personal access tokens (kalau di NestJS pakai JWT murni,
// tabel ini bisa dihapus dari schema).
model PersonalAccessToken {
  id             Int       @id @default(autoincrement())
  tokenableType  String    @map("tokenable_type") // polymorphic, no FK
  tokenableId    Int       @map("tokenable_id")   // polymorphic, no FK
  name           String    @db.Text
  token          String    @unique @db.VarChar(64)
  abilities      String?   @db.Text
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("personal_access_tokens")
}

model UserSession {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  tokenId        String?   @map("token_id") // "Refers to personal_access_tokens.id"
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.Text
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenId])
  @@map("user_sessions")
}

model PasswordHistory {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_history")
}

// ============================================================================
// ROLE & PERMISSION (spatie/laravel-permission)
// ============================================================================

model Permission {
  id        Int      @id @default(autoincrement())
  name      String
  guardName String   @map("guard_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles     RoleHasPermission[]
  models    ModelHasPermission[]

  @@unique([name, guardName])
  @@map("permissions")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String
  guardName String   @map("guard_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  permissions RoleHasPermission[]
  models      ModelHasRole[]

  @@unique([name, guardName])
  @@map("roles")
}

// model_has_permissions: polymorphic (model_type/model_id), no Prisma relation ke model target
model ModelHasPermission {
  permissionId Int    @map("permission_id")
  modelType    String @map("model_type")
  modelId      Int    @map("model_id")

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionId, modelId, modelType])
  @@index([modelId, modelType])
  @@map("model_has_permissions")
}

model ModelHasRole {
  roleId    Int    @map("role_id")
  modelType String @map("model_type")
  modelId   Int    @map("model_id")

  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, modelId, modelType])
  @@index([modelId, modelType])
  @@map("model_has_roles")
}

model RoleHasPermission {
  permissionId Int @map("permission_id")
  roleId       Int @map("role_id")

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([permissionId, roleId])
  @@map("role_has_permissions")
}

// ============================================================================
// SHOP / VENDOR
// ============================================================================

model Shop {
  id            Int      @id @default(autoincrement())
  ownerId       Int      @map("owner_id")
  name          String?
  slug          String?
  description   String?  @db.Text
  coverImage    Json?    @map("cover_image")
  logo          Json?
  isActive      Boolean  @default(false) @map("is_active")
  address       Json?
  settings      Json?
  notifications Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner            User      @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  staffUsers       User[]    @relation("UserCurrentShop")

  products         Product[]
  coupons          Coupon[]
  orders           Order[]
  attributes       Attribute[]
  balances         Balance[]
  withdraws        Withdraw[]
  refundPolicies   RefundPolicy[]
  refunds          Refund[]
  reviews          Review[]
  questions        Question[]
  faqs             Faq[]
  termsAndConditions TermsAndCondition[]
  conversations    Conversation[]
  participants     Participant[]
  categoryShops    CategoryShop[]
  userShops        UserShop[]
  storeNoticeShop  StoreNoticeShop[]
  ownershipTransfersFrom OwnershipTransfer[]

  @@map("shops")
}

model Balance {
  id                    Int      @id @default(autoincrement())
  shopId                Int      @map("shop_id")
  adminCommissionRate   Float?   @map("admin_commission_rate")
  totalEarnings         Float    @default(0) @map("total_earnings")
  withdrawnAmount       Float    @default(0) @map("withdrawn_amount")
  currentBalance        Float    @default(0) @map("current_balance")
  isCustomCommission    Boolean  @default(false) @map("is_custom_commission")
  paymentInfo           Json?    @map("payment_info")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  shop                  Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("balances")
}

model Withdraw {
  id            Int      @id @default(autoincrement())
  shopId        Int      @map("shop_id")
  amount        Float
  paymentMethod String?  @map("payment_method")
  status        String   // ENUM: App\Enums\WithdrawStatus (default: PENDING)
  details       String?  @db.Text
  note          String?  @db.Text
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("withdraws")
}

// user_shop pivot (staff assigned to a shop, e.g. "manages")
model UserShop {
  id     Int  @id @default(autoincrement())
  userId Int  @map("user_id")
  shopId Int  @map("shop_id")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("user_shop")
}

model Provider {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  providerUserId String   @map("provider_user_id")
  provider       String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("providers")
}

model BecameSeller {
  id          Int      @id @default(autoincrement())
  pageOptions Json     @map("page_options")
  language    String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("became_sellers")
}

model OwnershipTransfer {
  id                    Int      @id @default(autoincrement())
  transactionIdentifier String   @map("transaction_identifier") @db.VarChar(50)
  fromUserId            Int      @map("from")
  shopId                Int      @map("shop_id")
  toUserId              Int      @map("to")
  message               String?  @db.Text
  createdByUserId       Int      @map("created_by")
  status                String   // ENUM: App\Enums\DefaultStatusType (default: PENDING)
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  fromUser              User     @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser                User     @relation("TransferTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdByUser         User     @relation("TransferCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  shop                  Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([id, transactionIdentifier, createdAt])
  @@map("ownership_transfers")
}

model Commission {
  id          Int      @id @default(autoincrement())
  level       String
  subLevel    String   @map("sub_level")
  description String   @db.Text
  minBalance  Int      @map("min_balance")
  maxBalance  String   @map("max_balance")
  commission  Float
  image       Json?
  language    String   @default("en")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("commissions")
}

// ============================================================================
// CATALOG: TYPE / CATEGORY / ATTRIBUTE / TAG / AUTHOR / MANUFACTURER
// ============================================================================

model Type {
  id                  Int      @id @default(autoincrement())
  name                String
  settings            Json?
  slug                String
  language            String   @default("en")
  icon                String?
  promotionalSliders  Json?    @map("promotional_sliders")
  images              Json?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  products      Product[]
  manufacturers Manufacturer[]
  banners       Banner[]

  @@map("types")
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String
  language     String   @default("en")
  icon         String?
  image        Json?
  bannerImage  Json?    @map("banner_image")
  details      String?  @db.Text
  parentId     Int?     @map("parent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  parent       Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: Cascade)
  children     Category[] @relation("CategoryParent")

  products     CategoryProduct[]
  categoryShops CategoryShop[]

  @@map("categories")
}

model CategoryProduct {
  id         Int     @id @default(autoincrement())
  productId  Int     @map("product_id")
  categoryId Int     @map("category_id")

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_product")
}

model CategoryShop {
  shopId     Int      @map("shop_id")
  categoryId Int      @map("category_id")

  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([shopId, categoryId])
  @@map("category_shop")
}

model Attribute {
  id        Int      @id @default(autoincrement())
  slug      String
  language  String   @default("en")
  name      String
  shopId    Int?     @map("shop_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop      Shop?           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  values    AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          Int      @id @default(autoincrement())
  slug        String
  attributeId Int      @map("attribute_id")
  value       String
  language    String   @default("en")
  meta        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  products    AttributeProduct[]

  @@map("attribute_values")
}

model AttributeProduct {
  id                Int      @id @default(autoincrement())
  attributeValueId  Int      @map("attribute_value_id")
  productId         Int      @map("product_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  attributeValue    AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("attribute_product")
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  language  String   @default("en")
  icon      String?
  image     Json?
  details   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  products  ProductTag[]

  @@map("tags")
}

model ProductTag {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  tagId     Int     @map("tag_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("product_tag")
}

model Author {
  id          Int      @id @default(autoincrement())
  name        String
  isApproved  Boolean  @default(false) @map("is_approved")
  image       Json?
  coverImage  Json?    @map("cover_image")
  slug        String
  language    String   @default("en")
  bio         String?  @db.Text
  quote       String?  @db.Text
  born        String?
  death       String?
  languages   String?
  socials     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products    Product[]

  @@map("authors")
}

model Manufacturer {
  id          Int      @id @default(autoincrement())
  name        String
  isApproved  Boolean  @default(false) @map("is_approved")
  image       Json?
  coverImage  Json?    @map("cover_image")
  slug        String
  language    String   @default("en")
  typeId      Int      @map("type_id")
  description String?  @db.Text
  website     String?
  socials     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  type        Type      @relation(fields: [typeId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("manufacturers")
}

model ShippingClass {
  id        Int      @id @default(autoincrement())
  name      String
  amount    Float
  isGlobal  String   @default("true") @map("is_global") // NB: string di migration asli (harusnya boolean)
  type      String   // ENUM: App\Enums\ShippingType (default: FIXED)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products  Product[]

  @@map("shipping_classes")
}

model Banner {
  id          Int      @id @default(autoincrement())
  typeId      Int      @map("type_id")
  title       String   @db.Text
  description String?  @db.Text
  image       Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  type        Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@map("banners")
}

model TaxClass {
  id         Int      @id @default(autoincrement())
  country    String?
  state      String?
  zip        String?
  city       String?
  rate       Float
  name       String?
  isGlobal   Int?     @map("is_global")
  priority   Int?
  onShipping Boolean  @default(true) @map("on_shipping")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("tax_classes")
}

model DeliveryTime {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String
  icon        String
  description String?  @db.Text
  language    String   @default("en")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("delivery_times")
}

// ============================================================================
// PRODUCT / VARIATION / COUPON
// ============================================================================

model Product {
  id                         Int      @id @default(autoincrement())
  name                       String
  slug                       String
  description                String?  @db.Text
  typeId                     Int      @map("type_id")
  price                      Float?
  shopId                     Int?     @map("shop_id")
  authorId                   Int?     @map("author_id")
  manufacturerId             Int?     @map("manufacturer_id")
  isDigital                  Boolean  @default(false) @map("is_digital")
  isExternal                 Boolean  @default(false) @map("is_external")
  externalProductUrl         String?  @map("external_product_url")
  externalProductButtonText  String?  @map("external_product_button_text")
  blockedDates               String?  @map("blocked_dates")
  salePrice                  Float?   @map("sale_price")
  language                   String   @default("en")
  minPrice                   Float?   @map("min_price")
  maxPrice                   Float?   @map("max_price")
  sku                        String?
  quantity                   Int      @default(0)
  soldQuantity                Int      @default(0) @map("sold_quantity")
  inStock                    Boolean  @default(true) @map("in_stock")
  isTaxable                  Boolean  @default(false) @map("is_taxable")
  inFlashSale                Int      @default(0) @map("in_flash_sale") // NB: integer di migration asli (harusnya boolean)
  shippingClassId             Int?     @map("shipping_class_id")
  status                     String   @default("draft") // ENUM: App\Enums\ProductStatus
  visibility                 String   @default("public") // ENUM: App\Enums\ProductVisibilityStatus
  productType                String   @default("simple") @map("product_type") // ENUM: App\Enums\ProductType
  unit                       String
  height                     String?
  width                      String?
  length                     String?
  image                      Json?
  video                      Json?
  gallery                    Json?
  deletedAt                  DateTime? @map("deleted_at")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  type              Type            @relation(fields: [typeId], references: [id], onDelete: Cascade)
  shop              Shop?           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  author            Author?         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  manufacturer      Manufacturer?   @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  shippingClass      ShippingClass?  @relation(fields: [shippingClassId], references: [id])

  variationOptions  VariationOption[]
  orderProducts     OrderProduct[]
  categories        CategoryProduct[]
  attributeProducts AttributeProduct[]
  tags              ProductTag[]
  reviews           Review[]
  questions         Question[]
  wishlists         Wishlist[]
  meta              ProductsMeta[]
  availabilities    Availability[]
  dropoffLocations  DropoffLocationProduct[]
  pickupLocations   PickupLocationProduct[]
  featureLocations  FeatureProduct[]
  depositLocations  DepositProduct[]
  personLocations   PersonProduct[]
  flashSaleProducts FlashSaleProduct[]
  flashSaleRequestsProducts FlashSaleRequestsProduct[]

  @@map("products")
}

model ProductsMeta {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  type      String   @default("null")
  key       String
  value     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([key])
  @@map("products_meta")
}

model VariationOption {
  id           Int      @id @default(autoincrement())
  title        String
  image        Json?
  isDigital    Boolean  @default(false) @map("is_digital")
  price        String
  salePrice    String?  @map("sale_price")
  language     String   @default("en")
  quantity     Int
  soldQuantity Int      @default(0) @map("sold_quantity")
  isDisable    Boolean  @default(false) @map("is_disable")
  sku          String?
  options      Json
  productId    Int?     @map("product_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product      Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderProducts OrderProduct[]
  reviews      Review[]
  wishlists    Wishlist[]

  @@map("variation_options")
