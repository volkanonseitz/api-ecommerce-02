generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum ShippingType {
  fixed
  percentage
  free_shipping

  @@map("shipping_type")
}

enum CouponType {
  fixed
  percentage
  free_shipping

  @@map("coupon_type")
}

enum ProductStatus {
  under_review
  approved
  rejected
  publish
  unpublish
  draft
}

enum ProductType {
  simple
  variable
}

enum ProductVisibilityStatus {
  visibility_private
  visibility_public
  visibility_protected
}

enum OrderStatus {
  PENDING           @map("order-pending")
  PROCESSING        @map("order-processing")
  COMPLETED         @map("order-completed")
  CANCELLED         @map("order-cancelled")
  REFUNDED          @map("order-refunded")
  FAILED            @map("order-failed")
  AT_LOCAL_FACILITY @map("order-at-local-facility")
  OUT_FOR_DELIVERY  @map("order-out-for-delivery")
}

enum PaymentStatus {
  PENDING                @map("payment-pending")
  PROCESSING             @map("payment-processing")
  SUCCESS                @map("payment-success")
  FAILED                 @map("payment-failed")
  REVERSAL               @map("payment-reversal")
  REFUNDED               @map("payment-refunded")
  CASH_ON_DELIVERY       @map("payment-cash-on-delivery")
  CASH                   @map("payment-cash")
  WALLET                 @map("payment-wallet")
  AWAITING_FOR_APPROVAL  @map("payment-awaiting-for-approval")
}

enum WithdrawStatus {
  approved
  pending
  on_hold
  rejected
  processing
}

enum ResourceType {
  DROPOFF_LOCATION
  PICKUP_LOCATION
  PERSON
  DEPOSIT
  FEATURES
}

enum StoreNoticePriority {
  high
  medium
  low
}

enum StoreNoticeType {
  all_vendor
  specific_vendor
  all_shop
  specific_shop
}

enum FlashSaleType {
  percentage
  fixed_rate
}

enum DefaultStatusType {
  processing
  approved
  pending
  rejected
}

enum RefundPolicyStatus {
  approved
  pending
}

enum RefundPolicyTarget {
  vendor
  customer
}

enum RefundStatus {
  approved
  pending
  rejected
  processing
}

// Inline enum dari participants.type (bukan dari App\Enums)
enum ParticipantType {
  shop
  user
}

// ============================================================================
// AUTH / USER
// ============================================================================

model User {
  id                  Int       @id @default(autoincrement())
  name                String    @db.VarChar(255)
  email               String    @unique @db.VarChar(255)
  emailVerifiedAt     DateTime? @map("email_verified_at")
  password            String?   @db.VarChar(255)
  rememberToken       String?   @map("remember_token") @db.VarChar(100)
  isActive            Boolean   @default(true) @map("is_active")
  lockedUntil         DateTime? @map("locked_until")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts") @db.UnsignedSmallInt
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip") @db.VarChar(45)
  lastLoginUserAgent  String?   @map("last_login_user_agent") @db.VarChar(1000)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // relasi ke shop tempat dia jadi staff/karyawan (users.shop_id, nullable)
  shopId Int?  @map("shop_id")
  shop   Shop? @relation("UserCurrentShop", fields: [shopId], references: [id], onDelete: SetNull)

  // relasi 1-1 / 1-n
  profile              UserProfile?
  addresses            Address[]
  ownedShops           Shop[]              @relation("ShopOwner")
  shopMemberships      UserShop[]
  wallet               Wallet?
  providers            Provider[]
  paymentGateways      PaymentGateway[]
  sessions             UserSession[]
  passwordHistory      PasswordHistory[]
  coupons              Coupon[]
  wishlists            Wishlist[]
  reviews              Review[]
  questions            Question[]
  feedbacks            Feedback[]
  abusiveReports       AbusiveReport[]
  faqs                 Faq[]
  termsAndConditions   TermsAndCondition[]
  downloadTokens       DownloadToken[]
  orderedFiles         OrderedFile[]
  refunds              Refund[]
  conversations        Conversation[]
  messages             Message[]
  participants         Participant[]
  ordersAsCustomer     Order[]             @relation("OrderCustomer")

  notifyLogsReceived NotifyLog[] @relation("NotifyReceiver")
  notifyLogsSent     NotifyLog[] @relation("NotifySender")

  storeNoticesCreated StoreNotice[]     @relation("StoreNoticeCreatedBy")
  storeNoticesUpdated StoreNotice[]     @relation("StoreNoticeUpdatedBy")
  storeNoticeUser     StoreNoticeUser[]
  storeNoticeRead     StoreNoticeRead[]

  ownershipTransfersFrom    OwnershipTransfer[] @relation("OwnershipTransferFrom")
  ownershipTransfersTo      OwnershipTransfer[] @relation("OwnershipTransferTo")
  ownershipTransfersCreated OwnershipTransfer[] @relation("OwnershipTransferCreatedBy")

  roles       UserRole[]

  @@map("users")
}

model PasswordResetToken {
  email     String    @id @db.VarChar(255)
  token     String    @db.VarChar(255)
  createdAt DateTime? @map("created_at")

  @@map("password_reset_tokens")
}

model PasswordHistory {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("password_history")
}

model UserSession {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId        String?   @map("token_id") @db.VarChar(255)
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.Text
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([tokenId])
  @@map("user_sessions")
}

model Provider {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  provider       String   @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("providers")
}

// ---- RBAC (disederhanakan dari spatie/laravel-permission) -----------------

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  guardName String   @default("web") @map("guard_name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@unique([name, guardName])
  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  guardName String   @default("web") @map("guard_name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@unique([name, guardName])
  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionId, roleId])
  @@map("role_permissions")
}

// model_has_roles (disederhanakan, morph target selalu User)
model UserRole {
  userId Int @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  roleId Int @map("role_id")
  role   Role @relation(fields: [roleId], references: [id])

  @@id([roleId, userId])
  @@map("user_roles")
}

// ============================================================================
// SHOP / VENDOR
// ============================================================================

model Shop {
  id            Int      @id @default(autoincrement())
  ownerId       Int      @map("owner_id")
  owner         User     @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name          String?  @db.VarChar(255)
  slug          String?  @db.VarChar(255)
  description   String?  @db.Text
  coverImage    Json?    @map("cover_image")
  logo          Json?
  isActive      Boolean  @default(false) @map("is_active")
  address       Json?
  settings      Json?
  notifications Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  staff                User[]                @relation("UserCurrentShop")
  members              UserShop[]
  products             Product[]
  attributes           Attribute[]
  coupons              Coupon[]
  orders               Order[]
  balance              Balance?
  withdraws            Withdraw[]
  reviews              Review[]
  questions            Question[]
  conversations        Conversation[]
  participants         Participant[]
  faqs                 Faq[]
  termsAndConditions   TermsAndCondition[]
  refunds              Refund[]
  refundPolicies       RefundPolicy[]
  categories           CategoryShop[]
  storeNoticeShop      StoreNoticeShop[]
  ownershipTransfers   OwnershipTransfer[]

  @@map("shops")
}

model UserShop {
  id     Int  @id @default(autoincrement())
  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("user_shop")
}

model Balance {
  id                   Int      @id @default(autoincrement())
  shopId               Int      @unique @map("shop_id")
  shop                 Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  adminCommissionRate  Float?   @map("admin_commission_rate")
  totalEarnings        Float    @default(0) @map("total_earnings")
  withdrawnAmount      Float    @default(0) @map("withdrawn_amount")
  currentBalance       Float    @default(0) @map("current_balance")
  isCustomCommission   Boolean  @default(false) @map("is_custom_commission")
  paymentInfo          Json?    @map("payment_info")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("balances")
}

model Withdraw {
  id            Int            @id @default(autoincrement())
  shopId        Int            @map("shop_id")
  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  amount        Float
  paymentMethod String?        @map("payment_method") @db.VarChar(255)
  status        WithdrawStatus @default(pending)
  details       String?        @db.Text
  note          String?        @db.Text
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("withdraws")
}

model Commission {
  id          Int      @id @default(autoincrement())
  level       String   @db.VarChar(255)
  subLevel    String   @map("sub_level") @db.VarChar(255)
  description String   @db.Text
  minBalance  Int      @map("min_balance")
  maxBalance  String   @map("max_balance") @db.VarChar(255)
  commission  Float
  image       Json?
  language    String   @default("en") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("commissions")
}

model BecameSeller {
  id          Int      @id @default(autoincrement())
  pageOptions Json     @map("page_options")
  language    String   @unique @default("en") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("became_sellers")
}

model OwnershipTransfer {
  id                    Int               @id @default(autoincrement())
  transactionIdentifier String            @map("transaction_identifier") @db.VarChar(50)
  fromId                Int               @map("from")
  from                  User              @relation("OwnershipTransferFrom", fields: [fromId], references: [id], onDelete: Cascade)
  shopId                Int               @map("shop_id")
  shop                  Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  toId                  Int               @map("to")
  to                    User              @relation("OwnershipTransferTo", fields: [toId], references: [id], onDelete: Cascade)
  message               String?           @db.Text
  createdById           Int               @map("created_by")
  createdBy             User              @relation("OwnershipTransferCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  status                DefaultStatusType @default(pending)
  deletedAt             DateTime?         @map("deleted_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@index([id, transactionIdentifier, createdAt])
  @@map("ownership_transfers")
}

// ============================================================================
// CATALOG: TYPE / CATEGORY / PRODUCT / VARIATION / ATTRIBUTE
// ============================================================================

model Type {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(255)
  settings           Json?
  slug               String   @db.VarChar(255)
  language           String   @default("en") @db.VarChar(255)
  icon               String?  @db.VarChar(255)
  promotionalSliders Json?    @map("promotional_sliders")
  images             Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  products      Product[]
  manufacturers Manufacturer[]
  banners       Banner[]

  @@map("types")
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  slug         String    @db.VarChar(255)
  language     String    @default("en") @db.VarChar(255)
  icon         String?   @db.VarChar(255)
  image        Json?
  bannerImage  Json?     @map("banner_image")
  details      String?   @db.Text
  parentId     Int?      @map("parent")
  parent       Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: Cascade)
  children     Category[] @relation("CategoryParent")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  products CategoryProduct[]
  shops    CategoryShop[]

  @@map("categories")
}

model Product {
  id                         Int                      @id @default(autoincrement())
  name                       String                   @db.VarChar(255)
  slug                       String                   @db.VarChar(255)
  description                String?                  @db.Text
  typeId                     Int                      @map("type_id")
  type                       Type                     @relation(fields: [typeId], references: [id], onDelete: Cascade)
  price                      Float?
  shopId                     Int?                     @map("shop_id")
  shop                       Shop?                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  authorId                   Int?                     @map("author_id")
  author                     Author?                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  manufacturerId             Int?                     @map("manufacturer_id")
  manufacturer               Manufacturer?            @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  isDigital                  Boolean                  @default(false) @map("is_digital")
  isExternal                 Boolean                  @default(false) @map("is_external")
  externalProductUrl         String?                  @map("external_product_url") @db.VarChar(255)
  externalProductButtonText  String?                  @map("external_product_button_text") @db.VarChar(255)
  blockedDates               String?                  @map("blocked_dates") @db.VarChar(255)
  salePrice                  Float?                   @map("sale_price")
  language                   String                   @default("en") @db.VarChar(255)
  minPrice                   Float?                   @map("min_price")
  maxPrice                   Float?                   @map("max_price")
  sku                        String?                  @db.VarChar(255)
  quantity                   Int                      @default(0)
  soldQuantity               Int                      @default(0) @map("sold_quantity")
  inStock                    Boolean                  @default(true) @map("in_stock")
  isTaxable                  Boolean                  @default(false) @map("is_taxable")
  inFlashSale                Boolean                  @default(false) @map("in_flash_sale")
  shippingClassId            Int?                     @map("shipping_class_id")
  shippingClass              ShippingClass?           @relation(fields: [shippingClassId], references: [id])
  status                     ProductStatus            @default(draft)
  visibility                 ProductVisibilityStatus  @default(visibility_public)
  productType                ProductType              @default(simple) @map("product_type")
  unit                       String                   @db.VarChar(255)
  height                     String?                  @db.VarChar(255)
  width                      String?                  @db.VarChar(255)
  length                     String?                  @db.VarChar(255)
  image                      Json?
  video                      Json?
  gallery                    Json?
  deletedAt                  DateTime?                @map("deleted_at")
  createdAt                  DateTime                 @default(now()) @map("created_at")
  updatedAt                  DateTime                 @updatedAt @map("updated_at")

  variationOptions      VariationOption[]
  orderProducts         OrderProduct[]
  categories            CategoryProduct[]
  attributes            AttributeProduct[]
  tags                  ProductTag[]
  reviews               Review[]
  questions             Question[]
  wishlists             Wishlist[]
  meta                  ProductMeta[]
  availabilities        Availability[]
  dropoffLocations      DropoffLocationProduct[]
  pickupLocations       PickupLocationProduct[]
  features              FeatureProduct[]
  deposits              DepositProduct[]
  persons               PersonProduct[]
  flashSaleProducts     FlashSaleProduct[]
  flashSaleRequestsProducts FlashSaleRequestsProduct[]

  @@map("products")
}

model ProductMeta {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   @default("null") @db.VarChar(255)
  key       String   @db.VarChar(255)
  value     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("products_meta")
}

model VariationOption {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  image        Json?
  isDigital    Boolean   @default(false) @map("is_digital")
  price        String    @db.VarChar(255)
  salePrice    String?   @map("sale_price") @db.VarChar(255)
  language     String    @default("en") @db.VarChar(255)
  quantity     Int
  soldQuantity Int       @default(0) @map("sold_quantity")
  isDisable    Boolean   @default(false) @map("is_disable")
  sku          String?   @db.VarChar(255)
  options      Json
  productId    Int?      @map("product_id")
  product      Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orderProducts OrderProduct[]
  reviews       Review[]
  wishlists     Wishlist[]

  @@map("variation_options")
}

model Author {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  isApproved  Boolean  @default(false) @map("is_approved")
  image       Json?
  coverImage  Json?    @map("cover_image")
  slug        String   @db.VarChar(255)
  language    String   @default("en") @db.VarChar(255)
  bio         String?  @db.Text
  quote       String?  @db.Text
  born        String?  @db.VarChar(255)
  death       String?  @db.VarChar(255)
  languages   String?  @db.VarChar(255)
  socials     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("authors")
}

model Manufacturer {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  isApproved  Boolean  @default(false) @map("is_approved")
  image       Json?
  coverImage  Json?    @map("cover_image")
  slug        String   @db.VarChar(255)
  language    String   @default("en") @db.VarChar(255)
  typeId      Int      @map("type_id")
  type        Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)
  description String?  @db.Text
  website     String?  @db.VarChar(255)
  socials     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("manufacturers")
}

model CategoryProduct {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_product")
}

model CategoryShop {
  id         Int      @id @default(autoincrement())
  shopId     Int      @map("shop_id")
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_shop")
}

model Attribute {
  id        Int      @id @default(autoincrement())
  slug      String   @db.VarChar(255)
  language  String   @default("en") @db.VarChar(255)
  name      String   @db.VarChar(255)
  shopId    Int?     @map("shop_id")
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  values AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          Int      @id @default(autoincrement())
  slug        String   @db.VarChar(255)
  attributeId Int      @map("attribute_id")
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String   @db.VarChar(255)
  language    String   @default("en") @db.VarChar(255)
  meta        String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products AttributeProduct[]

  @@map("attribute_values")
}

model AttributeProduct {
  id               Int             @id @default(autoincrement())
  attributeValueId Int             @map("attribute_value_id")
  attributeValue   AttributeValue  @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  productId        Int             @map("product_id")
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@map("attribute_product")
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  slug      String    @db.VarChar(255)
  language  String    @default("en") @db.VarChar(255)
  icon      String?   @db.VarChar(255)
  image     Json?
  details   String?   @db.Text
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  products ProductTag[]

  @@map("tags")
}

model ProductTag {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     Int     @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("product_tag")
}

model ShippingClass {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(255)
  amount    Float
  isGlobal  String       @default("true") @map("is_global") @db.VarChar(255)
  type      ShippingType @default(fixed)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  products Product[]

  @@map("shipping_classes")
}

model TaxClass {
  id         Int      @id @default(autoincrement())
  country    String?  @db.VarChar(255)
  state      String?  @db.VarChar(255)
  zip        String?  @db.VarChar(255)
  city       String?  @db.VarChar(255)
  rate       Float
  name       String?  @db.VarChar(255)
  isGlobal   Int?     @map("is_global")
  priority   Int?
  onShipping Boolean  @default(true) @map("on_shipping")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

