  participants Participant[]

  @@map("conversations")
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  userId         Int      @map("user_id")
  body           String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants   Participant[]

  @@map("messages")
}

enum ParticipantType {
  shop
  user
}

model Participant {
  id             Int             @id @default(autoincrement())
  conversationId Int             @map("conversation_id")
  type           ParticipantType
  userId         Int             @map("user_id")
  shopId         Int             @map("shop_id")
  messageId      Int             @map("message_id")
  notify         Boolean         @default(false)
  lastRead       DateTime?       @map("last_read")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("participants")
}

model NotifyLog {
  id                  Int      @id @default(autoincrement())
  receiverId          Int      @map("receiver")
  senderId            Int?     @map("sender")
  notifyType          String?  @db.Text @map("notify_type")
  notifyReceiverType  String?  @db.Text @map("notify_receiver_type")
  isRead              Boolean  @default(false) @map("is_read")
  notifyTracker       String?  @db.Text @map("notify_tracker")
  notifyText          String?  @db.Text @map("notify_text")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  receiver            User     @relation("NotifyReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender              User?    @relation("NotifySender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("notify_logs")
}

// ============================================================================
// CMS: FAQ / TERMS
// ============================================================================

model Faq {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  shopId         Int?     @map("shop_id")
  faqTitle       String   @map("faq_title") @db.Text
  slug           String
  faqDescription String   @map("faq_description") @db.Text
  faqType        String?  @map("faq_type")
  issuedBy       String?  @map("issued_by")
  language       String?
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop           Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("faqs")
}

model TermsAndCondition {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  shopId      Int?     @map("shop_id")
  title       String   @db.Text
  slug        String
  description String   @db.Text
  type        String?
  issuedBy    String?  @map("issued_by")
  isApproved  Boolean  @default(false) @map("is_approved")
  language    String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("terms_and_conditions")
}

// ============================================================================
// FLASH SALE
// ============================================================================

model FlashSale {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String
  description  String?  @db.Text
  startDate    DateTime @default(now()) @map("start_date")
  endDate      DateTime @map("end_date")
  saleStatus   Boolean  @default(false) @map("sale_status")
  type         String   @default("percentage") // ENUM: App\Enums\FlashSaleType
  rate         Int?
  saleBuilder  Json?    @map("sale_builder")
  image        Json?
  coverImage   Json?    @map("cover_image")
  language     String?
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  requests     FlashSaleRequest[]
  products     FlashSaleProduct[]

  @@map("flash_sales")
}

model FlashSaleRequest {
  id                   Int      @id @default(autoincrement())
  title                String
  flashSaleId          Int      @map("flash_sale_id")
  requestedProductIds  Json?    @map("requested_product_ids")
  requestStatus        Boolean  @default(false) @map("request_status")
  note                 String?
  language             String   @default("en")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  flashSale            FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  requestsProducts     FlashSaleRequestsProduct[]

  @@map("flash_sale_requests")
}

model FlashSaleProduct {
  flashSaleId Int       @map("flash_sale_id")
  productId   Int       @map("product_id")

  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([flashSaleId, productId])
  @@map("flash_sale_products")
}

model FlashSaleRequestsProduct {
  flashSaleRequestsId Int              @map("flash_sale_requests_id")
  productId           Int              @map("product_id")

  flashSaleRequest    FlashSaleRequest @relation(fields: [flashSaleRequestsId], references: [id], onDelete: Cascade)
  product             Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([flashSaleRequestsId, productId])
  @@map("flash_sale_requests_products")
}